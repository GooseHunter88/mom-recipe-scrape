  "title": "Cilantro Lime Dressing",
  "serves": "",
  "category": "Gravy, Sauce & Dressing",
  "date": "2022-02-25",
  "ingredients": [
    "1/4 cup fresh lime juice ( 1 good sized lime)",
    "1/4 cup fresh cilantro",
    "1/3 cup honey",
    "1 garlic clove peeled & minced",
    "1 med sized jalapeno de-seeded de-ribbed",
    "3/4 grated fresh ginger",
    "2 teaspoon balsamic vinegar",
    "salt to taste ( I used 6 pinches of kosher salt)",
    "1/2 cup extra virgin olive oil"
  ],
  "instructions": "Combine all ingredients in a food processor and pour over salad.",
